.page_Base {
    width: 100%;
    height: 100%;
}

.popup_Base {
    display: flex;
    align-self: center;
    align-content: auto;
    align-items: stretch;
    justify-content: flex-start;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.9);
}

.panel_Base {
    background-image: none;
    background-color: rgba(0, 0, 0, 0);
    width: 100%;
}

